<p style="font-size:16px; margin:0 0 16px;">Beste {{ given_name or "alumnus" }},</p>

<p style="font-size:15px; line-height:1.5; margin:0 0 16px;">
  Je bent uitgenodigd als <strong>{{ persona }}</strong>.
  Bevestig je uitnodiging met je (test-)eduID en verifieer je alumnigegevens via de knop hieronder.
</p>

{% if persona_params.personal_message %}
<blockquote style="margin:0 0 16px; padding:12px 16px; background:#f4f7fb; border-left:3px solid #0a4d8c; font-style:italic;">
  {{ persona_params.personal_message }}
</blockquote>
{% endif %}

{% if persona_params.graduation_year %}
<p style="font-size:14px; color:#555; margin:0 0 16px;">Afstudeerjaar: {{ persona_params.graduation_year }}</p>
{% endif %}

<p style="margin:0 0 24px;">
  <a href="{{ accept_url }}"
     style="display:inline-block; background:#0a4d8c; color:#ffffff; text-decoration:none;
            padding:12px 22px; border-radius:6px; font-size:15px;">Accepteer je uitnodiging</a>
</p>

{% if expiry_date %}
<p style="font-size:13px; color:#777; margin:0 0 16px;">Deze uitnodiging verloopt op {{ expiry_date.split(' / ')[0] }}.</p>
{% endif %}

<p style="font-size:13px; color:#777; margin:0;">
  Alternatief: ga naar <strong>edupersona.nl</strong>, kies voor 'Accepteer een uitnodiging'
  en kopieer en plak daar deze uitnodigingscode:<br>
  <span style="display:inline-block; margin-top:6px; font-family:monospace; font-size:15px;
               color:#0a4d8c; background:#f4f7fb; padding:6px 10px; border-radius:4px;">{{ invite_code }}</span>
</p>
