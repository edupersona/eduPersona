{
  "DTAP": "dev",
  "storage_secret": "your-storage-secret-here",
  "log_level": "DEBUG",
  "console_logging": true,
  "base_url": "http://localhost:8080",
  "smtp_server": "localhost",
  "smtp_port": 25,
  "error_notification_from": "server@edupersona.nl",
  "error_notification_to": [
    "admin@your-domain.com"
  ],
  "postmark": {
    "token": "your-postmark-token-here",
    "message_stream": "your-message-stream-name"
  },
  "cleanup_api_key": "your-cleanup-api-key-here",
  "tenants": {
    "hvh": {
      "api_key": "your-tenant-api-key-here",
      "expiry_duration": 14,
      "theme": {
        "primary_color": "rgb(59, 130, 246)",
        "secondary_color": "#26a69a",
        "accent_color": "#9c27b0",
        "positive_color": "#21ba45"
      },
      "scim": {
        "scim_enabled": false,
        "scim_base_url": "http://localhost:8000",
        "bearer_token": "your-scim-bearer-token",
        "provision_groups": true
      },
      "admins": [
        {
          "display_name": "Your Name",
          "user": "your-user-id-hash-here",
          "authz": [
            "invitations",
            "simulator"
          ]
        }
      ],
      "fallback_admins": [
        {
          "user": "your_username",
          "password": "your_password",
          "authz": [
            "invitations",
            "simulator"
          ]
        }
      ],
      "oidc": {
        "eduid": {
          "label": "eduID",
          "CLIENT_ID": "your-client-id",
          "CLIENT_SECRET": "your-client-secret",
          "DOTWELLKNOWN": "https://connect.surfconext.nl/.well-known/openid-configuration",
          "REDIRECT_URI": "http://localhost:8080/oidc_callback",
          "login_hint": "https://login.eduid.nl",
          "force_login": true
        },
        "eduid_test": {
          "label": "eduID",
          "CLIENT_ID": "your-client-id",
          "CLIENT_SECRET": "your-client-secret",
          "DOTWELLKNOWN": "https://connect.test.surfconext.nl/.well-known/openid-configuration",
          "REDIRECT_URI": "http://localhost:8080/oidc_callback",
          "login_hint": "https://login.test.eduid.nl",
          "force_login": true
        },
        "diy_surfconext": {
          "label": "instellingsaccount",
          "CLIENT_ID": "your-client-id",
          "CLIENT_SECRET": "your-client-secret",
          "DOTWELLKNOWN": "https://connect.test.surfconext.nl/.well-known/openid-configuration",
          "REDIRECT_URI": "http://localhost:8080/oidc_callback",
          "login_hint": "https://idp.diy.surfconext.nl",
          "force_login": true
        }
      },
      "mail": {
        "sender_email": "noreply@edupersona.nl",
        "sender_name": "eduPersona"
      },
      "callback_secret": "your-callback-secret-here",
      "personas": {
        "gastdocent": {
          "display_name": "Gastdocent",
          "mail": {
            "layout": "layouts/hvh.jinja2",
            "body": "personas/gastdocent.jinja2"
          },
          "expected_params": {
            "faculteit": {
              "type": "string",
              "required": false
            },
            "personal_message": {
              "type": "text",
              "required": false
            }
          },
          "callback_outputs": [
            "eduid_login",
            "verify_mfa"
          ],
          "success_redirect_url": "https://login.canvas.uva.nl/?referrer=canvas.uva.nl",
          "callback_url": null,
          "completion_message": "Je hebt nu als gastdocent toegang tot de leeromgeving.",
          "cta_label": "Naar de leeromgeving",
          "steps": [
            {
              "class": "OIDCLoginStep",
              "id": "eduid_login",
              "config": {
                "idp": "eduid",
                "title": "Stap 1. Inloggen met eduID",
                "completed_text": "✓ Ingelogd met eduID",
                "primary_button": {
                  "label": "YES! I already have an eduID"
                },
                "secondary_button": {
                  "label": "No - I don't have an eduID yet",
                  "url": "https://mijn.eduid.nl/",
                  "hint": "Come back here after you've created it!"
                }
              }
            },
            {
              "class": "OIDCLoginStep",
              "id": "verify_mfa",
              "config": {
                "idp": "eduid",
                "title": "Stap 2. Verificatie tweede factor",
                "primary_button": {
                  "label": "Inloggen met eduID app"
                },
                "acr_value": "https://refeds.org/profile/mfa",
                "acr_failed_text": "De vereiste tweede factor (MFA) is niet voltooid. Probeer het opnieuw.",
                "completed_text": "✓ eduID app is correct geïnstalleerd",
                "disabled_text": "Voltooi eerst stap 1"
              }
            },
            {
              "class": "OIDCLoginStep",
              "id": "institutional_login",
              "config": {
                "idp": "diy_surfconext",
                "primary_button": {
                  "label": "Inloggen bij instelling...",
                  "hint": "Tip: gebruik professor5/professor5"
                },
                "title": "Stap 3. Verificatie instellingsaccount",
                "completed_text": "✓ Institutioneel ingelogd",
                "disabled_text": "Voltooi eerst stap 2"
              }
            },
            {
              "class": "VerifyConsentStep",
              "id": "consent",
              "config": {
                "title": "Stap 4: Gedragscode en toestemming",
                "primary_button": {
                  "label": "Openen..."
                },
                "dialog_title": "Gedragscode en toestemming",
                "consent_text": "static/hvh/docs/gedragscode.md",
                "consent_link": {
                  "label": "Lees het volledige privacybeleid",
                  "url": "https://www.surf.nl/en/about-surf/privacy"
                },
                "consent_label": "Ik heb het bovenstaande gelezen en geef toestemming",
                "confirm_button_label": "Bevestig toestemming",
                "completed_text": "✓ Toestemming gegeven",
                "disabled_text": "Voltooi eerst stap 3"
              }
            }
          ]
        },
        "alumnus": {
          "display_name": "Alumnus",
          "mail": {
            "layout": "layouts/hvh.jinja2",
            "body": "personas/alumnus.jinja2"
          },
          "expected_params": {},
          "callback_outputs": [
            "eduid_login",
            "alumni_db",
            "verify_mobile"
          ],
          "success_redirect_url": "https://example.org/alumni/welcome",
          "callback_url": null,
          "completion_message": "Je hebt nu toegang tot het portaal voor alumni.",
          "cta_label": "Naar het alumniportaal",
          "steps": [
            {
              "class": "OIDCLoginStep",
              "id": "eduid_login",
              "config": {
                "idp": "eduid",
                "title": "Stap 1. Inloggen met eduID",
                "completed_text": "✓ Ingelogd met eduID",
                "primary_button": {
                  "label": "YES! I already have an eduID"
                },
                "secondary_button": {
                  "label": "No - I don't have an eduID yet",
                  "url": "https://eduid.nl/home",
                  "hint": "Come back here after you've created it!"
                }
              }
            },
            {
              "class": "VerifyAlumniDb",
              "id": "alumni_db",
              "config": {
                "title": "Stap 2. Verifieer je gegevens in onze alumni-database",
                "completed_text": "✓ Alumnigegevens geverifieerd",
                "disabled_text": "Voltooi eerst stap 1"
              }
            },
            {
              "class": "VerifyMobileStep",
              "id": "verify_mobile",
              "config": {
                "title": "Stap 3. Verifieer je mobiele nummer",
                "completed_text": "✓ Mobiel nummer geverifieerd",
                "disabled_text": "Voltooi eerst stap 2",
                "help_text": "Voer je mobiele nummer in. Je ontvangt een code die je hieronder invult.",
                "mobile_label": "Mobile number",
                "code_label": "Verification code",
                "send_button_label": "Send code",
                "verify_button_label": "Verify",
                "resend_label": "Change number / resend"
              }
            }
          ]
        },
        "admin": {
          "display_name": "Admin",
          "mail": {
            "layout": "layouts/hvh.jinja2",
            "body": "personas/admin.jinja2"
          },
          "expected_params": {},
          "callback_url": null,
          "success_redirect_url": "/m/hvh/login",
          "completion_message": "Je bent aangemeld als admin/beheerder. Log in op eduPersona met je eduID.",
          "cta_label": "Naar de login",
          "completion": {
            "action": "admin_onboarding",
            "authz": [
              "invitations",
              "simulator"
            ],
            "notify_email": "admin@your-domain.com"
          },
          "steps": [
            {
              "class": "OIDCLoginStep",
              "id": "eduid_login",
              "config": {
                "idp": "eduid",
                "title": "Stap 1. Inloggen met je eduID app",
                "primary_button": {
                  "label": "Log in..."
                },
                "acr_value": "https://refeds.org/profile/mfa",
                "acr_failed_text": "De vereiste tweede factor (MFA) is niet voltooid. Probeer het opnieuw.",
                "completed_text": "✓ Ingelogd met eduID"
              }
            },
            {
              "class": "CollectIntakeStep",
              "id": "collect_intake",
              "config": {
                "title": "Stap 2. Vertel ons iets over je context",
                "completed_text": "✓ Gegevens ontvangen",
                "disabled_text": "Voltooi eerst stap 1"
              }
            }
          ]
        }
      }
    }
  }
}
